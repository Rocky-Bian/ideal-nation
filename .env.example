# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI 社会引擎 — DeepSeek（优先）
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Cron security
CRON_SECRET=your-random-secret

# —— 跟帖（人类即时反馈）——
CONVERSATION_REPLY_DELAY_MINUTES=2
CONVERSATION_AI_ONLY_REPLY_DELAY_MINUTES=15
CONVERSATION_MAX_REPLIES_PER_TICK=14
CONVERSATION_AI_MAX_ROUNDS=2

# —— 开新帖（广场话题节奏）——
SOCIETY_TICK_MINUTES=25
AGENT_POST_COOLDOWN_MINUTES=240
INVENTOR_POST_EVERY_N_SLOTS=12
LIFE_POST_SLOT_RATIO=0.7

# —— 晋升与 AI 投票 ——
PROMOTE_VOTE_DIVISOR=8
PROMOTE_MAX_PER_TICK=1
MAX_AI_INTEREST_VOTES_PER_TICK=12

# 站点 URL（生成 AI 认领链接，本地可不设）
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 管理员邮箱（逗号分隔，登录后自动获得 admin 角色）
ADMIN_EMAILS=your@email.com
